{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ymm-oss.github.io/fsl/schemas/fslc/causal/fsl-causal-evidence.v0.schema.json",
  "title": "fsl-causal-evidence v0 artifact",
  "type": "object",
  "required": [
    "schema_version",
    "evidence_id",
    "claims",
    "design",
    "support",
    "artifact_digest",
    "formal_result"
  ],
  "properties": {
    "schema_version": { "const": "fsl-causal-evidence.v0" },
    "evidence_id": { "type": "string", "minLength": 1 },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "version"],
        "properties": {
          "id": { "type": "string" },
          "version": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "design": {
      "enum": [
        "randomized_experiment",
        "quasi_experiment",
        "observational",
        "expert_judgment"
      ]
    },
    "source_study_id": { "type": ["string", "null"] },
    "derived_from": {
      "type": "array",
      "items": { "type": "string" }
    },
    "support": { "enum": ["supports", "challenges", "inconclusive"] },
    "scope": {
      "type": "object",
      "properties": {
        "population": { "$ref": "#/$defs/tokens" },
        "environment": { "$ref": "#/$defs/tokens" },
        "segment": { "$ref": "#/$defs/tokens" }
      },
      "additionalProperties": false
    },
    "period": {
      "type": "object",
      "properties": {
        "start": { "$ref": "#/$defs/date" },
        "end": { "$ref": "#/$defs/date" },
        "valid_until": { "$ref": "#/$defs/date" }
      },
      "additionalProperties": false
    },
    "estimate": {
      "type": "object",
      "properties": {
        "estimand": { "type": "string" },
        "value": { "type": "number" },
        "lower": { "type": "number" },
        "upper": { "type": "number" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": true
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "observation": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/observation" }]
    },
    "artifact_digest": { "$ref": "#/$defs/digest" },
    "formal_result": { "const": "not_run" }
  },
  "additionalProperties": false,
  "if": {
    "properties": { "observation": { "type": "object" } },
    "required": ["observation"]
  },
  "then": {
    "properties": {
      "design": { "const": "observational" },
      "support": { "const": "inconclusive" }
    }
  },
  "$defs": {
    "tokens": {
      "type": "array",
      "items": { "type": "string" }
    },
    "date": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "observation": {
      "type": "object",
      "required": ["kind", "expectation_id", "verdict", "assurance"],
      "properties": {
        "kind": { "const": "expectation_replay" },
        "expectation_id": { "type": "string" },
        "expectation_digest": { "$ref": "#/$defs/digest" },
        "verdict": { "enum": ["pass", "violated"] },
        "assurance": { "const": "replay-observed" },
        "event_counts": {
          "type": "object",
          "required": ["observed", "unmapped", "missing_required"],
          "properties": {
            "observed": { "type": "integer", "minimum": 0 },
            "unmapped": { "type": "integer", "minimum": 0 },
            "missing_required": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "digests": {
          "type": "object",
          "required": ["model", "log", "mapping"],
          "properties": {
            "model": { "$ref": "#/$defs/digest" },
            "log": { "$ref": "#/$defs/digest" },
            "mapping": { "$ref": "#/$defs/digest" },
            "study_protocol": {
              "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/digest" }]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
