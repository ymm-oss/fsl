{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ymm-oss.github.io/fsl/schemas/fslc/causal/causal-graph.v0.schema.json",
  "title": "fslc causal analyze graph projections v0",
  "type": "object",
  "required": [
    "result",
    "schema_version",
    "formal_result",
    "model",
    "projection",
    "nodes",
    "edges",
    "do_not_assume"
  ],
  "properties": {
    "result": { "const": "causal_analyzed" },
    "schema_version": { "const": "causal-graph.v0" },
    "formal_result": { "const": "not_run" },
    "model": { "type": "string" },
    "projection": {
      "enum": [
        "causal_graph",
        "causal_timeline",
        "causal_traceability_graph"
      ]
    },
    "timebase": { "type": "string" },
    "horizon": { "type": "integer", "minimum": 0 },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/edge" }
    },
    "paths": {
      "type": "array",
      "items": { "$ref": "#/$defs/path" }
    },
    "feedbacks": {
      "type": "array",
      "items": { "$ref": "#/$defs/feedback" }
    },
    "timelines": {
      "type": "array",
      "items": { "$ref": "#/$defs/timeline" }
    },
    "truncation": { "$ref": "#/$defs/truncation" },
    "do_not_assume": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  },
  "additionalProperties": true,
  "$defs": {
    "interval": {
      "type": "object",
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "time_reach": {
      "oneOf": [
        { "$ref": "#/$defs/interval" },
        { "const": "unknown" }
      ]
    },
    "polarity": { "enum": ["positive", "negative", "unknown"] },
    "node": {
      "type": "object",
      "required": ["id", "kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "enum": [
            "variable",
            "claim",
            "feedback",
            "evidence",
            "requirement",
            "action",
            "kpi",
            "property"
          ]
        },
        "role": {
          "enum": ["intervention", "mediator", "outcome", "context"]
        },
        "latent": { "type": "boolean" },
        "status": { "enum": ["active", "retired"] },
        "indicator_class": {
          "enum": ["leading", "intermediate", "lagging"]
        }
      },
      "additionalProperties": true
    },
    "edge": {
      "type": "object",
      "required": ["id", "kind", "source", "target"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "enum": [
            "claim",
            "binds",
            "observes",
            "proxy",
            "covers",
            "evidence_ref",
            "member"
          ]
        },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "polarity": { "$ref": "#/$defs/polarity" },
        "lag": { "$ref": "#/$defs/time_reach" },
        "persists": {
          "oneOf": [
            { "$ref": "#/$defs/interval" },
            { "enum": ["unknown", "unbounded"] }
          ]
        },
        "version": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["active", "retired"] },
        "basis": { "enum": ["hypothesis", "assumption"] }
      },
      "additionalProperties": true
    },
    "path": {
      "type": "object",
      "required": ["source", "target", "claims", "polarity"],
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "claims": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "polarity": { "$ref": "#/$defs/polarity" },
        "first_response": { "$ref": "#/$defs/time_reach" }
      },
      "additionalProperties": true
    },
    "feedback": {
      "type": "object",
      "required": ["id", "loop_class", "claims"],
      "properties": {
        "id": { "type": "string" },
        "loop_class": { "enum": ["reinforcing", "balancing", "unknown"] },
        "claims": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "cycle_lag": { "$ref": "#/$defs/time_reach" },
        "max_repetitions_within_horizon": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "const": "unknown" }
          ]
        },
        "recurrent": { "const": true }
      },
      "additionalProperties": true
    },
    "timeline": {
      "type": "object",
      "required": ["intervention", "outcome", "first_pass"],
      "properties": {
        "intervention": { "type": "string" },
        "outcome": { "type": "string" },
        "first_pass": { "$ref": "#/$defs/time_reach" },
        "via_feedback": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "truncation": {
      "type": "object",
      "required": ["paths_cap", "paths_truncated"],
      "properties": {
        "paths_cap": { "type": "integer", "minimum": 0 },
        "paths_truncated": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    }
  }
}
