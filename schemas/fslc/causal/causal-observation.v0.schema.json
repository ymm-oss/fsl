{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ymm-oss.github.io/fsl/schemas/fslc/causal/causal-observation.v0.schema.json",
  "title": "fslc causal observe-expectations CLI envelope",
  "type": "object",
  "required": [
    "fsl",
    "result",
    "schema_version",
    "formal_result",
    "model",
    "claims",
    "expectations",
    "events_observed",
    "artifacts_generated",
    "do_not_assume"
  ],
  "properties": {
    "fsl": { "const": "1.0" },
    "result": { "const": "causal_expectations_observed" },
    "schema_version": { "const": "causal-observation.v0" },
    "formal_result": { "const": "not_run" },
    "model": { "type": "string" },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "formal_assurance", "causal_support"],
        "properties": {
          "id": { "type": "string" },
          "formal_assurance": { "const": "not_run" },
          "causal_support": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "expectations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/expectation_result" }
    },
    "events_observed": { "type": "integer", "minimum": 0 },
    "artifacts_generated": { "type": "integer", "minimum": 0 },
    "artifact_digests": {
      "type": "array",
      "items": { "$ref": "#/$defs/digest" }
    },
    "do_not_assume": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 5
    }
  },
  "additionalProperties": false,
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "expectation_result": {
      "type": "object",
      "required": ["id", "verdict", "assurance", "within_ticks", "clock", "trigger_kind", "event_counts", "do_not_assume"],
      "properties": {
        "id": { "type": "string" },
        "verdict": { "enum": ["pass", "violated"] },
        "assurance": { "const": "replay-observed" },
        "within_ticks": { "type": "integer", "minimum": 0 },
        "clock": { "type": "string" },
        "trigger_kind": { "enum": ["action", "predicate"] },
        "derived_from_claim": { "type": ["string", "null"] },
        "event_counts": {
          "type": "object",
          "required": ["observed", "unmapped", "missing_required"],
          "properties": {
            "observed": { "type": "integer", "minimum": 0 },
            "unmapped": { "type": "integer", "minimum": 0 },
            "missing_required": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "do_not_assume": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
