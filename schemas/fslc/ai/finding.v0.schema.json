{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ymm-oss/fsl/schemas/fslc/ai/finding.v0.schema.json",
  "title": "fsl-ai finding v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "fsl",
    "result",
    "kind",
    "severity",
    "component",
    "contract",
    "tool",
    "failed_rule",
    "violation",
    "guarantee_kind",
    "evidence",
    "witness",
    "minimal_conflict_set",
    "repair_candidates",
    "assumptions"
  ],
  "properties": {
    "schema_version": {
      "const": "fsl-ai-finding.v0"
    },
    "fsl": {
      "enum": [
        "fsl-ai-hard.v0",
        "fsl-ai-agent.v0",
        "fsl-stochastic.v0",
        "fsl-ai-migration.v0",
        "fsl-ai-observed.v0",
        "fsl-ai-compat-profile.v0"
      ]
    },
    "result": {
      "enum": [
        "violated",
        "observed_mismatch",
        "dataset_invalid",
        "evaluator_untrusted",
        "slice_missing",
        "insufficient_samples",
        "inconclusive",
        "statistically_unsupported",
        "statistically_supported"
      ]
    },
    "kind": {
      "enum": [
        "ai_hard_contract_violation",
        "agent_structural_violation",
        "observed_contract_violation",
        "evaluator_backed_contract_violation",
        "statistical_contract_unsupported",
        "ai_migration_regression",
        "ai_observed_drift",
        "ai_observed_threshold_violation"
      ]
    },
    "severity": {
      "enum": ["info", "warning", "error"]
    },
    "component": {
      "type": "string"
    },
    "contract": {
      "type": "string"
    },
    "tool": {
      "type": ["string", "null"]
    },
    "failed_rule": {
      "type": "string"
    },
    "violation": {
      "type": "string"
    },
    "guarantee_kind": {
      "enum": [
        "syntactic_hard",
        "agent_structural",
        "runtime_observed",
        "evaluator_supported",
        "statistically_supported",
        "statistically_unsupported"
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "formal_proof"],
      "properties": {
        "kind": {
          "type": "string"
        },
        "formal_proof": {
          "type": "boolean"
        }
      }
    },
    "witness": {
      "type": "object"
    },
    "minimal_conflict_set": {
      "type": "object"
    },
    "repair_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "weakens_spec", "description"],
        "properties": {
          "kind": {
            "type": "string"
          },
          "weakens_spec": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text"],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      }
    },
    "redaction": {
      "type": "object"
    }
  }
}
