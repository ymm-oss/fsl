{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ymm-oss.github.io/fsl/schemas/fslc/approval-record.v0.schema.json",
  "title": "FSL spec-digest-bound approval record v0",
  "type": "object",
  "required": ["schema", "approved_at", "approver", "spec", "rendering", "baseline"],
  "properties": {
    "schema": {"const": "fslc-approval.v0"},
    "approved_at": {"type": "string"},
    "approver": {"type": "string", "minLength": 1},
    "spec": {
      "type": "object",
      "required": ["name", "entry", "digest", "digest_algorithm", "requirements"]
    },
    "rendering": {
      "type": "object",
      "required": ["kind", "path", "sha256", "generation"],
      "properties": {"kind": {"enum": ["html", "ledger", "scenarios"]}}
    },
    "baseline": {
      "type": "object",
      "required": ["digest", "entry", "files"],
      "properties": {
        "files": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    }
  },
  "additionalProperties": true
}
