spec ChainBusinessBroken {
  type Item = 0..0
  enum BSt { BOpen, BDone }

  state {
    st: Map<Item, BSt>
  }
  init {
    forall i: Item { st[i] = BOpen }
  }

  action finish(i: Item) {
    requires st[i] == BOpen
    st[i] = BDone
  }

  invariant ImpossibleInitiallyDone {
    forall i: Item { st[i] == BDone }
  }
}
