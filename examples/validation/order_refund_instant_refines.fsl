refinement InstantRefinesBase {
  impl OrderRefundInstant
  abs  OrderRefund

  map order[o: OrderId] = order[o]
  map stock = stock
  map refunded_total = refunded_total

  action pay(o)            -> pay(o)
  action ship(o)           -> ship(o)
  action cancel(o)         -> cancel(o)
  action refund(o)         -> refund(o)
  action instant_refund(o) -> refund(o)   // the claim "it's the same refund" — should break under checking
}
