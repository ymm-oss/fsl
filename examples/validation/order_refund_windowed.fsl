// Design variant: with a refund-period window (a design-layer implementation
// proposal for R5, which the abstract contract's ASSUME-5 deferred).
// Without editing the abstract contract examples/validation/order_refund.fsl at all,
// it adds at the detail layer the restriction that refund is possible only within
// WINDOW ticks after cancel.
spec OrderRefundWindowed {
  const CAP = 2
  const WINDOW = 2
  type OrderId = 0..2
  type Cnt = 0..3
  enum OSt { Cart, Paid, Shipped, Cancelled, Refunded }
  type Stock = 0..CAP
  type Age = 0..WINDOW                  // WINDOW = the expiry mark (refund only while age < WINDOW)

  state {
    order: Map<OrderId, OSt>,
    stock: Stock,
    refunded_total: Cnt,
    age: Map<OrderId, Age>              // ticks elapsed since cancel (exists only at the detail layer)
  }
  init {
    forall o: OrderId { order[o] = Cart }
    stock = CAP
    refunded_total = 0
    forall o: OrderId { age[o] = 0 }
  }

  action pay(o: OrderId) {
    requires order[o] == Cart
    requires stock > 0
    order[o] = Paid
    stock = stock - 1
  }
  action ship(o: OrderId) {
    requires order[o] == Paid
    order[o] = Shipped
  }
  action cancel(o: OrderId) {
    requires order[o] == Paid
    order[o] = Cancelled
    stock = stock + 1
    age[o] = 0                          // window starts
  }
  action refund(o: OrderId) {
    requires order[o] == Cancelled
    requires age[o] < WINDOW            // <- added time guard (a precondition strengthening)
    order[o] = Refunded
    refunded_total = refunded_total + 1
  }
  action tick() {                       // time advance (an internal event of the detail layer)
    forall o: OrderId {
      if order[o] == Cancelled and age[o] < WINDOW {
        age[o] = age[o] + 1
      }
    }
  }

  invariant StockConserved {
    stock + count(o: OrderId where (order[o] == Paid or order[o] == Shipped)) == CAP
  }
  invariant RefundLedger {
    refunded_total == count(o: OrderId where order[o] == Refunded)
  }

  // Positive-example pair: refund within the window is still possible (detects over-constraint)
  reachable FullyRefunded { exists o: OrderId { order[o] == Refunded } }
  // Positive-example pair: expiry actually happens (the window mechanism is not dead decoration)
  reachable WindowExpired { exists o: OrderId { order[o] == Cancelled and age[o] == WINDOW } }
}
