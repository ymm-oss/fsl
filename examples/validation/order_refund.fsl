// ════════════════════════════════════════════════════════════════
// Order payment / cancel / refund flow (with stock) — design-layer spec.
//
// A worked deliverable of the validation workflow (formalization note -> spec ->
// positive-example pair -> repair). See examples/validation/README.md.
// Assumptions are folded into the ASSUME tags below.
//
//   fslc verify examples/validation/order_refund.fsl --engine induction
// ════════════════════════════════════════════════════════════════
spec OrderRefund {
  // ASSUME-1: single SKU. Initial stock CAP=2. Three orders, to exercise interactions.
  // ASSUME-2: cancellation is allowed only when paid and not yet shipped (Paid). "No cancel after shipping."
  // ASSUME-3: stock is returned immediately on cancel (not at refund completion).
  // ASSUME-4: refunds are full-amount only. Amounts are not modeled; we track a count ledger (MODEL).
  // ASSUME-5: "refunds within a fixed window" (original requirement R5) is a discrete-time SLA.
  //           Not handled at the design layer; refundability is simply "possible if cancelled".
  //           The window check is delegated to time+deadline at the requirements layer
  //           (an initial version that brought a window flag into the design layer made
  //           refund unreachable, which reachable FullyRefunded detected).
  const CAP = 2
  type OrderId = 0..2
  type Cnt = 0..3
  enum OSt { Cart, Paid, Shipped, Cancelled, Refunded }
  type Stock = 0..CAP

  state {
    order: Map<OrderId, OSt>,
    stock: Stock,
    refunded_total: Cnt
  }
  init {
    forall o: OrderId { order[o] = Cart }
    stock = CAP
    refunded_total = 0
  }

  action pay(o: OrderId) {
    requires order[o] == Cart
    requires stock > 0
    order[o] = Paid
    stock = stock - 1
  }
  action ship(o: OrderId) {
    requires order[o] == Paid
    order[o] = Shipped
  }
  action cancel(o: OrderId) "ASSUME-2: no cancel after shipping" {
    requires order[o] == Paid
    order[o] = Cancelled
    stock = stock + 1
  }
  action refund(o: OrderId) {
    requires order[o] == Cancelled       // ASSUME-5: the window guard lives at the upper layer
    order[o] = Refunded
    refunded_total = refunded_total + 1
  }

  // Safety: stock conservation. The sum of held units (Paid/Shipped) and stock is constant.
  invariant StockConserved {
    stock + count(o: OrderId where (order[o] == Paid or order[o] == Shipped)) == CAP
  }
  // Safety: refund-ledger consistency. Double refunds are prevented by the state machine (one-way Cancelled->Refunded).
  invariant RefundLedger {
    refunded_total == count(o: OrderId where order[o] == Refunded)
  }

  // Positive-example pair (P4): check that refund is reachable — surfaces over-constraint / vacuity.
  reachable FullyRefunded { exists o: OrderId { order[o] == Refunded } }
}
