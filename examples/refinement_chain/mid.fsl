// Middle layer (requirements). Adds a review step, Review.
spec ChainMid {
  type Id = 0..1
  enum MSt { MOpen, MReview, MDone }
  state { st: Map<Id, MSt> }
  init { forall c: Id { st[c] = MOpen } }
  action start_review(c: Id) { requires st[c] == MOpen     st[c] = MReview }
  fair action finish(c: Id)  { requires st[c] == MReview   st[c] = MDone }
}
