// requirements ⊒ business. Review is invisible at the business layer = stutter.
refinement ChainMidRefinesTop {
  impl ChainMid
  abs  ChainTop
  map st[c: Id] = if st[c] == MOpen then TOpen
                  else if st[c] == MReview then TOpen
                  else TDone
  action start_review(c) -> stutter
  action finish(c)       -> finish(c)
}
