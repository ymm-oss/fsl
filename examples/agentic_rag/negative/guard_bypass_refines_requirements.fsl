// guard迂回designをrequirements層へ写すmapping。
//
// 期待:
// - `publish_without_guard -> answer` は、抽象状態がDraftedかつguard Uncheckedの
//   ままなので、requirements層answerのrequiresを満たせない。
// - `fslc refine ...` は refinement_failed / abs_requires_failed になる。
refinement AgenticRagGuardBypassRefinesRequirements {
  impl AgenticRagGuardBypassDesign
  abs  AgenticRagRequirements

  // 最小designの状態をrequirements層のCaseへ畳み込む。
  // DAnsweredへ写すことで「designは回答済みにしてしまった」事実を
  // requirements層の終端状態として観測させる。
  map req[r: Req] = Case {
    st:
      if d[r].phase == DNew then New
      else if d[r].phase == DReceived then Received
      else if d[r].phase == DClassified then Classified
      else if d[r].phase == DReady then EvidenceReady
      else if d[r].phase == DDrafted then Drafted
      else Answered,
    evidence: d[r].evidence,
    guard: d[r].guard,
    approval: d[r].approval,
    role: d[r].role,
    retry: d[r].retry,
    needs_tool: d[r].needs_tool,
    citation_ok: d[r].citation_ok,
    audit: d[r].audit
  }

  action receive(r) -> receive(r)
  action classify_answer(r) -> classify_answer(r)
  action retrieve_success(r) -> retrieve_success(r)
  action draft_answer(r) -> draft_answer(r)

  // 意図的に悪い対応。ここで抽象answerのrequiresが破れる。
  action publish_without_guard(r) -> answer(r)
}
