// tool承認迂回designをrequirements層へ写すmapping。
//
// 期待:
// - `execute_without_approval -> execute_tool` は、抽象状態がToolApprovalかつ
//   approval Requestedのままなので、requirements層execute_toolのrequiresを満たせない。
// - `fslc refine ...` は refinement_failed / abs_requires_failed になる。
refinement AgenticRagToolApprovalBypassRefinesRequirements {
  impl AgenticRagToolApprovalBypassDesign
  abs  AgenticRagRequirements

  map req[r: Req] = Case {
    st:
      if d[r].phase == DNew then New
      else if d[r].phase == DReceived then Received
      else if d[r].phase == DClassified then Classified
      else if d[r].phase == DReady then EvidenceReady
      else if d[r].phase == DToolApproval then ToolApproval
      else ActionExecuted,
    evidence: d[r].evidence,
    guard: d[r].guard,
    approval: d[r].approval,
    role: d[r].role,
    retry: d[r].retry,
    needs_tool: d[r].needs_tool,
    citation_ok: d[r].citation_ok,
    audit: d[r].audit
  }

  action set_operator(r) -> grant_operator(r)
  action receive(r) -> receive(r)
  action classify_tool(r) -> classify_tool(r)
  action retrieve_success(r) -> retrieve_success(r)
  action request_tool_approval(r) -> request_tool_approval(r)

  // 意図的に悪い対応。承認済みではないので抽象execute_toolのrequiresが破れる。
  action execute_without_approval(r) -> execute_tool(r)
}
