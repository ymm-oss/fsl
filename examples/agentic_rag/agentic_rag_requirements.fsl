// Agentic RAGサポートフロー [requirements層PoC]。
//
// 対象範囲:
// - 検索証拠、出力ガードレール、人間レビュー、副作用tool承認まわりの
//   制御契約を検査する。
// - 意味的なfaithfulnessや検索ランキング品質は証明しない。それらは外部評価器の
//   結果として扱い、この仕様ではevidence/citation状態で表す。
//
// 未確定のプロダクト判断:
// - 証拠不足のリクエストはRefusedまたはHumanReviewで終端してよい。
// - このPoCではHumanReviewを処理済み終端状態として扱う。
// - SLA/deadlineはまだモデル化していない。
requirements AgenticRagRequirements {
  // ReqはリクエストID。liveness探索を軽くするため、個々のIDに意味差がない
  // 対称なIDとして宣言している。
  symmetric type Req = 0..1
  // Retryは「残りリトライ回数」。0になったら再検索を続けず、拒否または
  // 人間レビューへ進める。
  type Retry = 0..2

  // Stageはリクエスト単位の外部可視なライフサイクル。
  // 内部実装では複数agentや複数toolに分かれてよいが、requirements層では
  // PM/レビュアが追える粒度に止める。
  enum Stage {
    New,
    Received,
    Classified,
    Retrieving,
    EvidenceReady,
    EvidenceBad,
    Drafted,
    GuardFailed,
    ToolApproval,
    ToolApproved,
    Answered,
    Refused,
    HumanReview,
    ActionExecuted
  }
  // Evidenceは外部RAG評価器の判定結果を抽象化したもの。
  // FSLは「Adequateの判定が意味的に正しい」ことは証明しない。
  enum Evidence { Missing, Adequate, Inadequate }
  // Guardは出力ガードレールの結果。Failed後にAnsweredへ進めないことを
  // forbiddenとrequiresで検査する。
  enum Guard { Unchecked, Passed, Failed }
  // Approvalは副作用toolの承認状態。Requestedだけでは実行不可。
  enum Approval { NoApproval, Requested, Approved, Denied }
  // Roleは副作用toolを承認・実行できる権限を表す。
  enum Role { Public, Operator }

  // Caseは1リクエストの論理状態。実装のDB schemaではなく、conformance testで
  // observe()が投影すべき契約上の状態である。
  struct Case {
    // 現在の処理段階。
    st: Stage,
    // RAG評価器が返した証拠十分性。
    evidence: Evidence,
    // 出力ガードレールの状態。
    guard: Guard,
    // 副作用toolの承認状態。
    approval: Approval,
    // リクエストを扱う主体の権限。PoCではgrant_operatorで事前付与する。
    role: Role,
    // 検索失敗時に残っている再試行回数。
    retry: Retry,
    // このリクエストが副作用toolを必要とするか。
    needs_tool: Bool,
    // 引用が取得済みかつユーザーscope内である、という外部ACL/filter結果。
    citation_ok: Bool,
    // receive済みで監査ログに乗ったか。終端状態に入る前提として検査する。
    audit: Bool
  }

  state {
    // リクエストごとの論理状態。Reqは小さな有限範囲にしてモデル検査する。
    req: Map<Req, Case>
  }

  init {
    forall r: Req {
      req[r] = Case {
        st: New,
        evidence: Missing,
        guard: Unchecked,
        approval: NoApproval,
        role: Public,
        retry: 2,
        needs_tool: false,
        citation_ok: false,
        audit: false
      }
    }
  }

  requirement REQ-1 "受け付けたユーザーリクエストはエージェントワークフローに入り、監査記録される" {
    // PoC用の権限付与。実システムでは認証・認可層からobserveされる値になる。
    action grant_operator(r: Req) {
      requires req[r].st == New
      req[r].role = Operator
    }

    // receiveは監査境界。ここを通っていない終端処理は
    // HandledRequestsWereAuditedで禁止する。
    action receive(r: Req) {
      requires req[r].st == New
      req[r].st = Received
      req[r].audit = true
    }
  }

  requirement REQ-2 "エージェントはリクエストが副作用toolを必要とするか分類する" {
    // 通常回答パス。副作用toolは不要。
    fair action classify_answer(r: Req) {
      requires req[r].st == Received
      req[r].st = Classified
      req[r].needs_tool = false
    }

    // toolパス。後段では明示承認がない限りexecute_toolできない。
    fair action classify_tool(r: Req) {
      requires req[r].st == Received
      req[r].st = Classified
      req[r].needs_tool = true
    }
  }

  requirement REQ-3 "回答には十分な検索証拠と許可された引用が必要である" {
    // 検索・rerank・ACL/filter・引用検査をまとめた成功イベント。
    // ここでは外部評価器の結果としてAdequate/citation_ok=trueを受け取る。
    fair action retrieve_success(r: Req) {
      requires req[r].st == Classified or req[r].st == Retrieving
      req[r].st = EvidenceReady
      req[r].evidence = Adequate
      req[r].citation_ok = true
    }

    // 検索失敗・証拠不足・引用不可のいずれかをまとめた失敗イベント。
    // この状態から直接answerへ行けないことをforbiddenで検査する。
    fair action retrieve_empty(r: Req) {
      requires req[r].st == Classified or req[r].st == Retrieving
      req[r].st = EvidenceBad
      req[r].evidence = Inadequate
      req[r].citation_ok = false
    }

    // 再検索はretry budgetを必ず消費する。無限retryを避けるため、
    // retryが0になるとこのactionはenabledでなくなる。
    fair action retry_retrieve(r: Req) {
      requires req[r].st == EvidenceBad
      requires req[r].retry > 0
      req[r].st = Retrieving
      req[r].retry = req[r].retry - 1
    }

    // 証拠不足を拒否で閉じる運用。
    fair action refuse_low_evidence(r: Req) {
      requires req[r].st == EvidenceBad
      requires req[r].retry == 0
      req[r].st = Refused
    }

    // 証拠不足を人間レビューへ送る運用。Refusedとどちらを既定にするかは
    // 未確定なので、PoCでは両方を許容している。
    fair action review_low_evidence(r: Req) {
      requires req[r].st == EvidenceBad
      requires req[r].retry == 0
      req[r].st = HumanReview
    }
  }

  requirement REQ-4 "下書き回答は最終回答前に出力ガードレールを通過しなければならない" {
    // 回答下書きは証拠が十分で、かつ副作用toolを必要としない場合だけ作る。
    // toolを必要とする場合はToolApprovalへ進む。
    fair action draft_answer(r: Req) {
      requires req[r].st == EvidenceReady
      requires not req[r].needs_tool
      req[r].st = Drafted
      req[r].guard = Unchecked
    }

    // 出力ガードレール成功。状態はDraftedのまま、guardだけPassedにする。
    fair action output_guard_pass(r: Req) {
      requires req[r].st == Drafted
      requires req[r].guard == Unchecked
      req[r].guard = Passed
    }

    // 出力ガードレール失敗。ここからanswerへ進む経路は存在しない。
    fair action output_guard_fail(r: Req) {
      requires req[r].st == Drafted
      requires req[r].guard == Unchecked
      req[r].st = GuardFailed
      req[r].guard = Failed
    }

    // 最終回答。requiresが契約の中心で、証拠・引用・guard通過をすべて要求する。
    fair action answer(r: Req) {
      requires req[r].st == Drafted
      requires req[r].evidence == Adequate
      requires req[r].citation_ok
      requires req[r].guard == Passed
      req[r].st = Answered
    }

    // guard失敗を拒否で閉じる。
    fair action refuse_guard_failure(r: Req) {
      requires req[r].st == GuardFailed
      req[r].st = Refused
    }

    // guard失敗を人間レビューへ送る。
    fair action review_guard_failure(r: Req) {
      requires req[r].st == GuardFailed
      req[r].st = HumanReview
    }
  }

  requirement REQ-5 "副作用toolにはoperatorロールと明示承認が必要である" {
    // tool承認待ちへ進めるのは、証拠が十分でtoolが必要な場合だけ。
    fair action request_tool_approval(r: Req) {
      requires req[r].st == EvidenceReady
      requires req[r].needs_tool
      req[r].st = ToolApproval
      req[r].approval = Requested
    }

    // 承認はoperatorだけが行える。Publicのままapprove_toolする経路はFB-5で
    // must-forbidとして固定している。
    fair action approve_tool(r: Req) {
      requires req[r].st == ToolApproval
      requires req[r].role == Operator
      req[r].st = ToolApproved
      req[r].approval = Approved
    }

    // 承認拒否はRefusedで閉じる。
    fair action deny_tool(r: Req) {
      requires req[r].st == ToolApproval
      req[r].st = Refused
      req[r].approval = Denied
    }

    // 副作用toolの実行。承認済み・operatorの両方を要求する。
    // 実装ではここが外部API、DB更新、メール送信などに対応する。
    fair action execute_tool(r: Req) {
      requires req[r].st == ToolApproved
      requires req[r].approval == Approved
      requires req[r].role == Operator
      req[r].st = ActionExecuted
    }
  }

  // Safety: Answeredに到達した全リクエストは、証拠・引用・guard通過を満たす。
  // requiresだけでなくinvariantにもして、将来のaction追加で抜け道ができた場合に
  // 反例として見えるようにしている。
  invariant AnswerHasEvidenceAndGuard "REQ-3: 最終回答には十分な証拠、許可された引用、通過済みガードレールが必要" {
    forall r: Req {
      req[r].st == Answered => (
        req[r].evidence == Adequate and req[r].citation_ok and req[r].guard == Passed
      )
    }
  }

  // Safety: EvidenceReadyという状態名の意味を固定する。
  // mutation sliceでは、retrieve_success相当のassignmentが欠けても、
  // 後続actionが閉じるだけで見逃せる変異が残った。状態名自体に
  // 「十分な証拠と許可済み引用がある」という意味を持たせる。
  invariant EvidenceReadyHasEvidenceAndCitation "REQ-3: EvidenceReadyは十分な証拠と許可済み引用を表す" {
    forall r: Req {
      req[r].st == EvidenceReady => (
        req[r].evidence == Adequate and req[r].citation_ok
      )
    }
  }

  // Safety: 下書きはEvidenceReadyからしか作れないので、下書き中も
  // 証拠と引用の前提を保つ。answer直前だけでなく、guard評価中の状態も
  // PMが読める契約として明示する。
  invariant DraftedHasEvidenceAndCitation "REQ-3: Draftedは回答可能な証拠と引用を保持している" {
    forall r: Req {
      req[r].st == Drafted => (
        req[r].evidence == Adequate and req[r].citation_ok
      )
    }
  }

  // Safety: EvidenceBadは証拠不足または引用不可の評価結果を表す。
  // design層にも同じ不変条件があり、requirements層でも状態名の意味を揃える。
  invariant EvidenceBadMeansNoCitation "REQ-3: EvidenceBadは不十分な証拠と引用不可を表す" {
    forall r: Req {
      req[r].st == EvidenceBad => (
        req[r].evidence == Inadequate and not req[r].citation_ok
      )
    }
  }

  // Safety: guard失敗状態ではguard値もFailedでなければならない。
  // StageだけがGuardFailed、またはguardだけがFailedという半端な状態を防ぐ。
  invariant GuardFailedMeansFailedGuard "REQ-4: GuardFailedは出力ガードレール失敗を表す" {
    forall r: Req {
      req[r].st == GuardFailed => req[r].guard == Failed
    }
  }

  // Safety: ActionExecutedは承認済みoperatorだけ。tool実行actionのrequiresに加え、
  // 状態としても常に成り立つことを確認する。
  invariant ToolExecutionApproved "REQ-5: 副作用tool実行にはoperator承認が必要" {
    forall r: Req {
      req[r].st == ActionExecuted => (
        req[r].approval == Approved and req[r].role == Operator
      )
    }
  }

  // Safety: 承認待ちstageとapproval値を同期させる。
  // Requestedは「承認待ちだが、まだ実行不可」という外部可視状態である。
  invariant ToolApprovalMeansRequested "REQ-5: ToolApprovalはRequested承認状態を表す" {
    forall r: Req {
      req[r].st == ToolApproval => req[r].approval == Requested
    }
  }

  // Safety: 承認済みstageとapproval値を同期させる。
  // execute_toolのrequiresだけに依存せず、ToolApprovedという状態名自体を
  // 明示承認済みの意味に固定する。
  invariant ToolApprovedMeansApproved "REQ-5: ToolApprovedはApproved承認状態を表す" {
    forall r: Req {
      req[r].st == ToolApproved => req[r].approval == Approved
    }
  }

  // Safety: 終端処理はreceiveを通って監査済みでなければならない。
  // grant_operatorだけで終端に入るような抜け道があればここで落ちる。
  invariant HandledRequestsWereAudited "REQ-1: 処理済みリクエストは監査済みワークフローに入っていなければならない" {
    forall r: Req {
      (req[r].st == Answered or req[r].st == Refused or req[r].st == HumanReview or req[r].st == ActionExecuted) => req[r].audit
    }
  }

  // Transition safety: retry_retrieveはretry budgetを必ず1だけ消費する。
  // 状態不変条件だけでは「Retrievingへ戻ったがretryを減らしていない」変異を
  // 見逃しやすいため、old/newの関係として固定する。
  trans RetryConsumesOneBudget "REQ-3: retry時はbudgetを1だけ消費する" {
    forall r: Req {
      (old(req[r].st) == EvidenceBad and req[r].st == Retrieving) => (
        req[r].retry == old(req[r].retry) - 1
      )
    }
  }

  // Transition safety: 副作用tool実行済みへ入る直前はToolApprovedでなければならない。
  // ActionExecutedの状態不変条件だけだと、承認待ちstageから直接実行する
  // shortcutを見逃す可能性があるため、遷移元stageも契約に含める。
  trans ExecutionComesFromApprovedStage "REQ-5: ActionExecutedはToolApprovedからだけ入る" {
    forall r: Req {
      req[r].st == ActionExecuted => (
        old(req[r].st) == ToolApproved or old(req[r].st) == ActionExecuted
      )
    }
  }

  // Liveness: 受け付け後、処理中状態に残り続けてはいけない。
  // 各actionをfairにしているので、enabledな処理が永久に選ばれないlassoは除外される。
  // 実運用でworker停止を許すなら、ここはSLA/deadlineや障害modeと合わせて再設計する。
  leadsTo RequestEventuallyHandled "REQ-6: 受け付けたリクエストは最終的に回答、拒否、レビュー、またはtool実行に到達する" {
    forall r: Req {
      (req[r].st == Received or req[r].st == Classified or req[r].st == Retrieving or req[r].st == EvidenceReady or req[r].st == EvidenceBad or req[r].st == Drafted or req[r].st == GuardFailed or req[r].st == ToolApproval or req[r].st == ToolApproved)
        ~>
      (req[r].st == Answered or req[r].st == Refused or req[r].st == HumanReview or req[r].st == ActionExecuted)
    }
  }

  // Positive examples: 仕様が過剰に強くなっておらず、主要な成功・例外パスに
  // 実際に到達できることをwitnessとして確認する。
  reachable CanAnswer {
    exists r: Req { req[r].st == Answered }
  }

  reachable CanRefuse {
    exists r: Req { req[r].st == Refused }
  }

  reachable CanReview {
    exists r: Req { req[r].st == HumanReview }
  }

  reachable CanExecuteTool {
    exists r: Req { req[r].st == ActionExecuted }
  }

  // Acceptance: 正常なRAG回答パス。
  acceptance AC-1 "証拠に基づく回答パス" {
    receive(0)
    classify_answer(0)
    retrieve_success(0)
    draft_answer(0)
    output_guard_pass(0)
    answer(0)
    expect req[0].st == Answered
  }

  // Acceptance: 証拠不足時にretryを使い切り、人間レビューへ送るパス。
  acceptance AC-2 "証拠不足ではリトライを使い切ってレビューへ進む" {
    receive(0)
    classify_answer(0)
    retrieve_empty(0)
    retry_retrieve(0)
    retrieve_empty(0)
    retry_retrieve(0)
    retrieve_empty(0)
    review_low_evidence(0)
    expect req[0].st == HumanReview
  }

  // Acceptance: 証拠不足時にretryを使い切り、拒否で閉じるパス。
  // CanRefuseだけだとtool承認拒否でも満たせるため、低証拠拒否の正規pathを
  // executable exampleとして別に固定する。
  acceptance AC-3 "証拠不足ではリトライを使い切って拒否へ進む" {
    receive(0)
    classify_answer(0)
    retrieve_empty(0)
    retry_retrieve(0)
    retrieve_empty(0)
    retry_retrieve(0)
    retrieve_empty(0)
    refuse_low_evidence(0)
    expect req[0].st == Refused
  }

  // Acceptance: operator承認後に副作用toolを実行するパス。
  acceptance AC-4 "承認済みoperatorによるtool実行パス" {
    grant_operator(0)
    receive(0)
    classify_tool(0)
    retrieve_success(0)
    request_tool_approval(0)
    approve_tool(0)
    execute_tool(0)
    expect req[0].st == ActionExecuted
  }

  // Must-forbid: guard pass前のanswerがrequiresで拒否されること。
  forbidden FB-1 "出力ガードレール通過前の回答は拒否される" {
    receive(0)
    classify_answer(0)
    retrieve_success(0)
    draft_answer(0)
    answer(0)
    expect rejected
  }

  // Must-forbid: guard failed後のanswerが拒否されること。
  forbidden FB-2 "出力ガードレール失敗後の回答は拒否される" {
    receive(0)
    classify_answer(0)
    retrieve_success(0)
    draft_answer(0)
    output_guard_fail(0)
    answer(0)
    expect rejected
  }

  // Must-forbid: 証拠不足のままanswerできないこと。
  forbidden FB-3 "不十分な証拠での回答は拒否される" {
    receive(0)
    classify_answer(0)
    retrieve_empty(0)
    answer(0)
    expect rejected
  }

  // Must-forbid: retry budgetが残っている間は、証拠不足を拒否で閉じてはいけない。
  // retry_liveness_sliceで重要だった境界条件を、本体requirementsにも戻す。
  forbidden FB-6 "retryが残る間は証拠不足を拒否で閉じない" {
    receive(0)
    classify_answer(0)
    retrieve_empty(0)
    refuse_low_evidence(0)
    expect rejected
  }

  // Must-forbid: retry budgetが残っている間は、人間レビューにも送らない。
  // 早期レビューを許す運用に変える場合は、このforbiddenを明示的に見直す。
  forbidden FB-7 "retryが残る間は証拠不足をレビューで閉じない" {
    receive(0)
    classify_answer(0)
    retrieve_empty(0)
    review_low_evidence(0)
    expect rejected
  }

  // Must-forbid: 承認待ち状態から直接tool実行できないこと。
  forbidden FB-4 "承認前の副作用tool実行は拒否される" {
    grant_operator(0)
    receive(0)
    classify_tool(0)
    retrieve_success(0)
    request_tool_approval(0)
    execute_tool(0)
    expect rejected
  }

  // Must-forbid: Public roleのままtool承認できないこと。
  forbidden FB-5 "非operatorは副作用tool実行を承認できない" {
    receive(0)
    classify_tool(0)
    retrieve_success(0)
    request_tool_approval(0)
    approve_tool(0)
    expect rejected
  }
}
