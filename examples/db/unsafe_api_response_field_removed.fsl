dbsystem UnsafeApiResponseFieldRemoved {
  database app {
    schema 0
    table users {
      column id: Int present backfilled not_null;
    }
  }

  artifact server_v2 {
    responds response.email_normalized;
  }

  artifact ios_v1 {
    expects response.email;
  }

  environment prod {
    schema 0..0;
    active server_v2 when schema 0..0;
    may_exist ios_v1 when schema 0..0;
  }
}
