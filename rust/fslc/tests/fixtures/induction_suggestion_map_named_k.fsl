spec MapNamedK {
    type Case = 0..1
    state {
        k: Map<Case, Int>,
        y: Int
    }
    init {
        k[0] = 0
        k[1] = 0
        y = 0
    }
    action bump(c: Case) {
        k[c] = k[c] + 1
    }
    action step(c: Case) {
        requires k[c] < -100
        k[c] = k[c] + 1
        y = y + 1
    }
    invariant Sync { y <= 4 }
}
