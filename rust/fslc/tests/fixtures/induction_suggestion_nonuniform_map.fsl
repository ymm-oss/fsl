spec NonuniformMapCounter {
  type Case = 0..1

  state {
    audit: Map<Case, Int>,
    y: Int
  }

  init {
    audit[0] = 0
    audit[1] = 1
    y = 0
  }

  action step(c: Case) {
    requires audit[c] < -100
    audit[c] = audit[c] + 1
    y = y + 1
  }

  invariant Sync { y <= 4 }
}
